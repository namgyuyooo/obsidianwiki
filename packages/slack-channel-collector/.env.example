# Slack token with conversations:read and channels:history/groups:history scopes as needed.
# Keep this outside git. The packaged collector.env carries every non-secret
# default; this file is for deployment-specific overrides.
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_USER_TOKEN=
SLACK_TOKEN=

# Defaults target #tf_cross_team_sales.
SLACK_WORKSPACE_NAME=RTM Slack
SLACK_COLLECT_CHANNEL=tf_cross_team_sales
SLACK_COLLECT_CHANNEL_ID=C01L5SA4Y4C
SLACK_CHANNELS=tf_cross_team_sales
SLACK_CHANNEL_TYPES=public_channel,private_channel

# JSON-only export paths.
SLACK_COLLECT_OUTPUT_ROOT=./data/slack
SLACK_COLLECT_STATE_PATH=./data/slack_state.json
SLACK_EXPORT_ROOT=./data/slack
SLACK_STATE_PATH=./data/slack_state.json

# Daily schedule. 24:00 is represented as next-day 00:00.
SLACK_COLLECT_SCHEDULE_TIME=24:00
SLACK_COLLECT_TIMEZONE=Asia/Seoul

# First run lookback. Later runs use incremental state.
SLACK_COLLECT_LOOKBACK_HOURS=24
SLACK_COLLECT_LIMIT=5000
SLACK_OLDEST_DAYS=1
SLACK_HISTORY_LIMIT=5000
SLACK_COLLECT_INCLUDE_THREADS=true
SLACK_COLLECT_INCLUDE_FILES=true
SLACK_INCLUDE_THREADS=true
SLACK_INCLUDE_FILES=true

# Rate limiting and run window.
SLACK_COLLECT_API_MIN_INTERVAL_SECONDS=1.2
SLACK_COLLECT_PAGE_PAUSE_SECONDS=1.0
SLACK_COLLECT_THREAD_PAUSE_SECONDS=1.0
SLACK_API_MIN_INTERVAL_SECONDS=1.2
SLACK_HISTORY_PAGE_PAUSE_SECONDS=1.0
SLACK_THREAD_PAUSE_SECONDS=1.0
SLACK_CHANNEL_PAUSE_SECONDS=2.5
SLACK_RATE_LIMIT_COOLDOWN_SECONDS=20.0
SLACK_COLLECT_MAX_MINUTES=10

# GLM compatibility values are reflected for downstream processors. This raw
# JSON collector does not call GLM unless a future processor is added.
GLM_API_URL=
GLM_API_KEY=
GLM_MODEL=glm-5.1
GLM_LIGHT_MODEL=
GLM_LIGHT_MAX_TOKENS=1200
GLM_DECISION_MODEL=
GLM_DECISION_MAX_TOKENS=1800
GLM_DECISION_FINAL_MODEL=
GLM_DECISION_FINAL_MAX_TOKENS=1800
GLM_CONFLICT_MODEL=
GLM_CONFLICT_MAX_TOKENS=1200
GLM_FILE_ANALYSIS_MODEL=
GLM_VLM_MODEL=
GLM_PAPERCLIP_MODEL=
GLM_SLACK_FILTER_MODEL=
GLM_SLACK_FILTER_MAX_TOKENS=1200
GLM_AVAILABLE_MODELS=
GLM_THINKING_TYPE=disabled
GLM_THINKING_BUDGET_TOKENS=0
GLM_CHAT_MAX_TOKENS=2000
GLM_CHAT_STREAM=false
GLM_CONTEXT_MODE=standard
