# Path to the SQLite DB built by packages/customer-db (defaults to that path).
RTM_CUSTOMER_DB=/absolute/path/to/rtm_customer.db

# Slack message-writing guide surfaced in the UI (defaults to
# packages/customer-db/docs/SLACK_MESSAGE_GUIDE.md).
# RTM_SLACK_GUIDE=/absolute/path/to/SLACK_MESSAGE_GUIDE.md

# Workspace base for building permalinks to original Slack messages.
RTM_SLACK_WORKSPACE_URL=https://rtm.slack.com

# CORS origins for the Vite dev server (comma separated).
RTM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Slack sync job wiring (optional; when RTM_SLACK_CHANNEL_ID is unset,
# POST /api/sync returns a "not configured" message instead of failing).
# RTM_SLACK_CHANNEL_ID=C07RMMQC8GP
# RTM_SLACK_EXPORT_DIR=/absolute/path/to/exports

# Slack sync inputs:
#   - Live collect needs a Slack token (SLACK_BOT_TOKEN / SLACK_USER_TOKEN).
#   - Thread callback requires Slack scope chat:write and the app in the channel.
#   - Slack user sync requires users:read; profile detail requires users.profile:read.
#   - User email requires users:read.email.
#   - Or test without live Slack by pointing at a collector export JSON:
# RTM_SLACK_EXPORT_FILE=/absolute/path/to/slack_export.json

# GLM / LLM (optional, OpenAI-compatible) — natural-language search, company
# auto-inference, cross-team fallback parsing. Swap providers by changing these.
# When unset, search falls back to keyword matching and GLM features are disabled.
# GLM_API_URL=https://api.z.ai/api/paas/v4     # z.ai '코딩 요금제'는 /api/coding/paas/v4 (비전 미지원)
# GLM_API_KEY=...
# GLM_MODEL=glm-5.2
# GLM_EMBEDDING_MODEL=embedding-3

# ── Business-card OCR (vision) ───────────────────────────────────────────────
# 백엔드를 나중에 바꿔도 코드 변경 없이 env로 전환됩니다.
# VISION_PROVIDER: auto(기본) | mcp | rest | off
#   auto → MCP(z.ai 코딩플랜 GLM-4.6V) 먼저, 실패 시 REST 폴백
#   mcp  → z.ai Vision MCP 전용   rest → OpenAI 호환 vision 엔드포인트 전용
# VISION_PROVIDER=auto
#
# (A) z.ai Vision MCP — 코딩 요금제에 포함된 GLM-4.6V. Node.js >= 22 필요.
#     Z_AI_API_KEY 없으면 GLM_API_KEY를 사용합니다.
# Z_AI_API_KEY=...
# Z_AI_MODE=ZAI
# VISION_MCP_PACKAGE=@z_ai/mcp-server@latest        # 다른 vision MCP로 교체 시 변경
# VISION_MCP_COMMAND=["npx","-y","@z_ai/mcp-server@latest"]   # 완전 커스텀 실행 명령(JSON)
#
# (B) OpenAI 호환 REST vision — coding 엔드포인트는 /api/coding/paas→/api/paas 자동 전환.
# GLM_VISION_API_URL=https://api.z.ai/api/paas/v4   # 미설정 시 GLM_API_URL 기반 자동 추론
# GLM_VISION_MODEL=glm-4.5v                          # 로컬 VLM 예: qwen2.5vl (+ Ollama URL)

# Built frontend served by the API (defaults to webapp/frontend/dist).
# RTM_FRONTEND_DIST=/absolute/path/to/dist
