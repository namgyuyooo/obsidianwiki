# Path to the SQLite DB built by packages/customer-db (defaults to that path).
RTM_CUSTOMER_DB=/absolute/path/to/rtm_customer.db

# Slack message-writing guide surfaced in the UI (defaults to
# packages/customer-db/docs/SLACK_MESSAGE_GUIDE.md).
# RTM_SLACK_GUIDE=/absolute/path/to/SLACK_MESSAGE_GUIDE.md

# Workspace base for building permalinks to original Slack messages.
RTM_SLACK_WORKSPACE_URL=https://rtm.slack.com

# CORS origins for the Vite dev server (comma separated).
RTM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Slack sync job wiring (optional; when RTM_SLACK_CHANNEL_ID is unset,
# POST /api/sync returns a "not configured" message instead of failing).
# RTM_SLACK_CHANNEL_ID=C07RMMQC8GP
# RTM_SLACK_EXPORT_DIR=/absolute/path/to/exports

# Slack sync inputs:
#   - Live collect needs a Slack token (SLACK_BOT_TOKEN / SLACK_USER_TOKEN).
#   - Or test without live Slack by pointing at a collector export JSON:
# RTM_SLACK_EXPORT_FILE=/absolute/path/to/slack_export.json

# GLM (optional) — enables natural-language search and company auto-inference.
# When unset, search falls back to keyword matching and infer is disabled.
# GLM_API_URL=https://api.example.com/v1
# GLM_API_KEY=...
# GLM_MODEL=glm-4

# Built frontend served by the API (defaults to webapp/frontend/dist).
# RTM_FRONTEND_DIST=/absolute/path/to/dist
