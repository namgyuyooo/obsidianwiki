WIKI_RAG_HOST=127.0.0.1
WIKI_RAG_PORT=8797

# Use either WIKI_RAG_ROOTS or the two explicit roots below.
# WIKI_RAG_ROOTS=/absolute/path/to/obsidian/Wiki:/absolute/path/to/obsidian/L1_memory
WIKI_RAG_WIKI_ROOT=/absolute/path/to/obsidian/Wiki
WIKI_RAG_L1_ROOT=/absolute/path/to/obsidian/L1_memory

# Optional OpenAI-compatible chat completion endpoint.
# Works with OpenAI-compatible gateways and the existing GLM-compatible env names.
WIKI_RAG_LLM_API_URL=
WIKI_RAG_LLM_API_KEY=
WIKI_RAG_LLM_MODEL=
