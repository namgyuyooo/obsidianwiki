# Conservative real-world defaults for all-day Drive mirroring.
# Change only RCLONE_REMOTE_PATH first if you want to start small.

RCLONE_REMOTE=gdrive
RCLONE_REMOTE_PATH=2026년도 전자부품산업기술개발
RCLONE_MIRROR_ROOT=/Users/rtm/Documents/GitHub/Obsidian_wiki/obsidianwiki/automation/drive_wikify/runtime/mirror

# Be intentionally slow and steady.
RCLONE_BWLIMIT=1M
RCLONE_TPSLIMIT=1
RCLONE_CHECKERS=1
RCLONE_TRANSFERS=1
