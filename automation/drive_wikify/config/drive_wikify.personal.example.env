# Single source of truth for personal-vault drive_wikify settings.
# Copy this file to a separate personal env file such as docker/config/personal_drive_wikify.env.

DRIVE_DELETE_SOURCE=false

# Personal vault runtime
WIKI_ROOT=../obsidianwiki-personal/obsidian/Wiki
L1_MEMORY_ROOT=../obsidianwiki-personal/obsidian/L1_memory
COVERAGE_TRACKER=../obsidianwiki-personal/obsidian/Wiki/log.md
LOG_PAGE=../obsidianwiki-personal/obsidian/Wiki/log.md
STATE_DIR=../obsidianwiki-personal/automation/drive_wikify/runtime
LOCK_FILE=../obsidianwiki-personal/automation/drive_wikify/runtime/drive_wikify.lock
DELETION_LOG=../obsidianwiki-personal/automation/drive_wikify/runtime/deletion_log.jsonl
AUTO_CREATE_PROJECT_SPACE=true
CLEANUP_LOCAL_MIRROR=true

ALLOWED_FILE_TYPES=hwp,hwpx,pdf,docx,pptx,xlsx,xls,csv,html,htm,gdoc,gsheet,gslides
MAX_FOLDERS_PER_RUN=3
MAX_FILES_PER_FOLDER=50
MAX_FETCH_DOCS=3
CHUNK_SIZE_MIN_CHARS=8000
CHUNK_SIZE_MAX_CHARS=15000

RCLONE_REMOTE=
RCLONE_REMOTE_PATH=
RCLONE_MIRROR_ROOT=../obsidianwiki-personal/automation/drive_wikify/runtime/mirror
RCLONE_BWLIMIT=1M
RCLONE_TPSLIMIT=1
RCLONE_CHECKERS=1
RCLONE_TRANSFERS=1
RCLONE_COPY_MAX_MINUTES=30
RCLONE_EXCLUDE_PATTERNS=Github/**,GitHub/**,github/**,Obsidian_wiki/**,obsidianwiki/**

DRIVE_NAME=personal-root
MANIFEST_PATH=../obsidianwiki-personal/automation/drive_wikify/runtime/manifest.json
RUN_OUTPUT_PATH=../obsidianwiki-personal/automation/drive_wikify/runtime/run_output.json

GLM_API_URL=https://api.z.ai/api/coding/paas/v4
GLM_API_KEY=
GLM_MODEL=glm-5.1
GLM_AVAILABLE_MODELS=glm-5.1,glm-4.5,glm-4.5-air,glm-4-flash
GLM_THINKING_TYPE=enabled
GLM_THINKING_BUDGET_TOKENS=8192
GLM_CHAT_MAX_TOKENS=10000
GLM_CHAT_STREAM=true
GLM_CONTEXT_MODE=standard
