# Single source of truth for drive_wikify settings.
# Copy this file to config/.env for local use.

# Safety
DRIVE_DELETE_SOURCE=false

# Wiki runtime
WIKI_ROOT=obsidian/Wiki
L1_MEMORY_ROOT=obsidian/L1_memory
COVERAGE_TRACKER=obsidian/Wiki/Common/Drive_Wikify_Coverage_Tracker.md
LOG_PAGE=obsidian/Wiki/log.md
STATE_DIR=automation/drive_wikify/runtime
LOCK_FILE=automation/drive_wikify/runtime/drive_wikify.lock
DELETION_LOG=automation/drive_wikify/runtime/deletion_log.jsonl
AUTO_CREATE_PROJECT_SPACE=true
CLEANUP_LOCAL_MIRROR=true

# Batch and extraction
ALLOWED_FILE_TYPES=hwp,hwpx,pdf,docx,pptx,xlsx,xls,csv,html,htm,gdoc,gsheet,gslides
MAX_FOLDERS_PER_RUN=3
MAX_FILES_PER_FOLDER=50
MAX_FETCH_DOCS=3
CHUNK_SIZE_MIN_CHARS=8000
CHUNK_SIZE_MAX_CHARS=15000

# rclone collect
RCLONE_REMOTE=gdrive
RCLONE_REMOTE_PATH=
RCLONE_MIRROR_ROOT=automation/drive_wikify/runtime/mirror
RCLONE_BWLIMIT=1M
RCLONE_TPSLIMIT=1
RCLONE_CHECKERS=1
RCLONE_TRANSFERS=1
RCLONE_COPY_MAX_MINUTES=30
# Prevent self-ingestion loops. The Obsidian_wiki repo is uploaded under Drive/Github.
RCLONE_EXCLUDE_PATTERNS=Github/**,GitHub/**,github/**,Obsidian_wiki/**,obsidianwiki/**

# Optional convenience defaults for CLI
DRIVE_NAME=gdrive-root
MANIFEST_PATH=automation/drive_wikify/runtime/manifest.json
RUN_OUTPUT_PATH=automation/drive_wikify/runtime/run_output.json

# GLM API for digest and chat
# Z.ai Lite Coding Plan uses https://api.z.ai/api/coding/paas/v4
GLM_API_URL=https://api.z.ai/api/coding/paas/v4
GLM_API_KEY=
GLM_MODEL=glm-5.1
GLM_AVAILABLE_MODELS=glm-5.1,glm-4.5,glm-4.5-air,glm-4-flash
GLM_THINKING_TYPE=enabled
GLM_THINKING_BUDGET_TOKENS=8192
GLM_CHAT_MAX_TOKENS=10000
GLM_CHAT_STREAM=true
GLM_CONTEXT_MODE=standard

# OpenClaw automation trigger
# Leave blank to reuse GLM_API_URL / GLM_API_KEY.
OPENCLAW_WEBHOOK_URL=
OPENCLAW_API_KEY=

# Paperclip local control plane
PAPERCLIP_URL=http://127.0.0.1:3000
PAPERCLIP_API_KEY=

# Slack raw evidence collector
# One of SLACK_BOT_TOKEN / SLACK_USER_TOKEN is required for local Slack collection.
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_WORKSPACE_NAME=
SLACK_CHANNEL_TYPES=public_channel,private_channel
SLACK_CHANNELS=
SLACK_EXPORT_ROOT=obsidian/raw/exports/slack
SLACK_STATE_PATH=automation/wiki_api/runtime/slack_collection_state.json
SLACK_HISTORY_LIMIT=200
SLACK_OLDEST_DAYS=30
SLACK_INCLUDE_THREADS=true
SLACK_INCLUDE_FILES=true
SLACK_API_MIN_INTERVAL_SECONDS=1.2
SLACK_HISTORY_PAGE_PAUSE_SECONDS=1.0
SLACK_THREAD_PAUSE_SECONDS=1.0
SLACK_CHANNEL_PAUSE_SECONDS=2.5
SLACK_RATE_LIMIT_COOLDOWN_SECONDS=20
SLACK_COLLECT_MAX_MINUTES=10
SLACK_FILTER_WITH_GLM=true
SLACK_FILTER_EXPORT_ROOT=obsidian/raw/exports/slack_filtered
SLACK_PROJECT_CHANNEL_PREFIXES=pjt_,pjt-,hubble-pjt-
SLACK_COMPANY_CHANNEL_PREFIXES=sales_,rtm,0_rtm,1_rtm,team_,ai,vision_,apollo,hubble-general
SLACK_MIXED_CHANNEL_PREFIXES=tf_
SLACK_PROJECT_WIKI_ROOT=obsidian/Wiki/Common/Slack_Project_Intake
SLACK_COMPANY_WIKI_ROOT=obsidian/Wiki/Common/Slack_Company_News
