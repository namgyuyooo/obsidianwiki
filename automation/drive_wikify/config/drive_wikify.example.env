# Single source of truth for drive_wikify settings.
# Copy this file to config/.env for local use.

# Safety
DRIVE_DELETE_SOURCE=false

# Wiki runtime
WIKI_ROOT=obsidian/Wiki
L1_MEMORY_ROOT=obsidian/L1_memory
COVERAGE_TRACKER=obsidian/Wiki/Common/Drive_Wikify_Coverage_Tracker.md
LOG_PAGE=obsidian/Wiki/log.md
STATE_DIR=automation/drive_wikify/runtime
LOCK_FILE=automation/drive_wikify/runtime/drive_wikify.lock
DELETION_LOG=automation/drive_wikify/runtime/deletion_log.jsonl
AUTO_CREATE_PROJECT_SPACE=true
CLEANUP_LOCAL_MIRROR=true

# Batch and extraction
ALLOWED_FILE_TYPES=hwp,hwpx,pdf,docx,pptx,gdoc,gslides
MAX_FOLDERS_PER_RUN=3
MAX_FILES_PER_FOLDER=50
MAX_FETCH_DOCS=3
CHUNK_SIZE_MIN_CHARS=8000
CHUNK_SIZE_MAX_CHARS=15000

# rclone collect
RCLONE_REMOTE=gdrive
RCLONE_REMOTE_PATH=2026년도 전자부품산업기술개발
RCLONE_MIRROR_ROOT=automation/drive_wikify/runtime/mirror
RCLONE_BWLIMIT=1M
RCLONE_TPSLIMIT=1
RCLONE_CHECKERS=1
RCLONE_TRANSFERS=1

# Optional convenience defaults for CLI
DRIVE_NAME=2026년도 전자부품산업기술개발
MANIFEST_PATH=automation/drive_wikify/runtime/manifest.json
RUN_OUTPUT_PATH=automation/drive_wikify/runtime/run_output.json
